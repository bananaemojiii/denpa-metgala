# Chain — "base" | "optimism" (default: base)
UMA_CHAIN=base

# RPC — use Alchemy/Infura/QuickNode for reliability during live event
BASE_RPC_URL=https://mainnet.base.org
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Asserter wallet — must hold USDC for bond + ETH/native token for gas
# Fund with 500 USDC minimum before the event
ASSERTER_PRIVATE_KEY=0x...

# Admin auth — must match apps/web ADMIN_SECRET
ADMIN_SECRET=

# Redis — must match apps/web and ingest
REDIS_URL=redis://localhost:6379

# HTTP port for this service
PORT=3001
